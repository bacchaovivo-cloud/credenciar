# ==========================================
# BACCH PRODUÇÕES - AMBIENTE DE CONFIGURAÇÃO
# ==========================================

# BANCO DE DADOS
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=bacch_sistema

# SEGURANÇA (OBRIGATÓRIO)
# -------------------------
JWT_SECRET=super_segredo_bacch_2026
FORENSIC_SALT=bacch_military_securit_2026_salt
NODE_ENV=development # Altere para 'production' em produção

# SERVIDOR
PORT=3001

# MODO DE TESTES E SIMULAÇÃO
# -------------------------
# 'fake': Simula impressora térmica com delay de 2.5s (Sem hardware real)
# 'real': Tenta conectar via TCP/IP na rede local (Requer hardware)
PRINTER_MODE=fake

# 'true': Ativa latência randômica e erros 500 esporádicos (Modo Caos)
# 'false': Comportamento normal da API
CHAOS_MODE=false

# CONFIGURAÇÃO DE IMPRESSORA (FALLBACK)
DEFAULT_PRINTER_IP=192.168.1.100
DEFAULT_PRINTER_PORT=9100
